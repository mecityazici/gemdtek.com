# ==============================================================================
# GEMDTEK — production .env template
# Copy to .env on the server, fill in real values, never commit.
# ==============================================================================

# ----- Application -----------------------------------------------------------
APP_NAME=GEMDTEK
APP_ENV=production
APP_KEY=                         # run: php artisan key:generate (once, then keep)
APP_DEBUG=false
APP_URL=https://gemdtek.com
APP_TIMEZONE=Europe/Istanbul

APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=tr_TR

# When set, Laravel maintenance pages render this view instead of the default
APP_MAINTENANCE_DRIVER=file

# ----- Logging ---------------------------------------------------------------
LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error                  # production: only error+ to keep log size sane
LOG_DAILY_DAYS=14

# ----- Database (MySQL on Natro) ---------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1                # Natro genelde localhost
DB_PORT=3306
DB_DATABASE=gemdtek_main         # cPanel'de oluşturduğun DB adı (genelde user_dbname formatında)
DB_USERNAME=gemdtek_app          # cPanel DB user
DB_PASSWORD=                     # cPanel DB password
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ----- Cache / Session / Queue ----------------------------------------------
# 'file' = en güvenli shared hosting default (DB tablosu da kurmaz)
# Queue ayarı aşağıda QUEUE_CONNECTION'da — varsayılan 'sync' (worker gerektirmez).
BROADCAST_CONNECTION=log
CACHE_STORE=file
CACHE_PREFIX=gemdtek

# ⚠️ 'sync' = mail/bildirim istek anında inline gönderilir; paylaşımlı hostta queue
#    worker GEREKMEZ — varsayılan ve güvenli. 'database' SADECE çalışan bir queue
#    worker varsa (cPanel cron, bkz. DEPLOY.md §1.4) kullan; aksi halde TÜM mailler
#    (iletişim, başvuru, sponsor lead, newsletter onay/kampanya, etkinlik kaydı)
#    'jobs' tablosunda sessizce birikir ve hiç gönderilmez.
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true       # production HTTPS sonrası true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# ----- Filesystem ------------------------------------------------------------
FILESYSTEM_DISK=public

# ----- Mail ------------------------------------------------------------------
# Önerilen sağlayıcılar:
#   - Brevo (eski Sendinblue) — ücretsiz 300 mail/gün, smtp-relay.brevo.com:587
#   - Resend — modern, ücretsiz 3000/ay, smtp.resend.com:465 (TLS)
#   - Natro SMTP — info@gemdtek.com hesabı üzerinden (varsayılan)
MAIL_MAILER=smtp
MAIL_HOST=mail.gemdtek.com       # veya brevo / resend host
MAIL_PORT=465                    # 465 (SSL) veya 587 (TLS)
MAIL_USERNAME=info@gemdtek.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl              # 'tls' for port 587
MAIL_FROM_ADDRESS="info@gemdtek.com"
MAIL_FROM_NAME="${APP_NAME}"

# Form/contact/sponsor lead bildirimleri buraya gider (boş = MAIL_FROM_ADDRESS)
FORM_NOTIFICATION_EMAIL=info@gemdtek.com

# ----- Admin (seed) ----------------------------------------------------------
# RolesAndAdminSeeder bu değerlerle ilk super_admin'i oluşturur.
# İlk deploy sonrası şifreyi panelden değiştir.
ADMIN_EMAIL=admin@gemdtek.com
ADMIN_PASSWORD=                  # GÜÇLÜ rastgele şifre — örn `openssl rand -base64 24`

# ----- Telescope / Pulse / Debug (kapalı) -----------------------------------
TELESCOPE_ENABLED=false
PULSE_ENABLED=false
DEBUGBAR_ENABLED=false

# ----- Vite (build-time, runtime'da kullanılmaz) -----------------------------
VITE_APP_NAME="${APP_NAME}"

# ----- PWA / Service Worker --------------------------------------------------
# Layout @production blade içinde olduğu için APP_ENV=production yeter.
# Manuel kapatmak istersen layout'ta @production yerine @env('canary') yap.

# ----- Trusted Proxies (Cloudflare/CDN arkasındaysan) ------------------------
# TRUSTED_PROXIES=*
# TRUSTED_HOSTS=gemdtek.com
