# =============================================================
# GEMDTEK production environment template
# Copy to .env on Natro, fill the placeholders, never commit
# =============================================================

APP_NAME=GEMDTEK
APP_ENV=production
APP_KEY=                        # php artisan key:generate çalıştır
APP_DEBUG=false
APP_TIMEZONE=Europe/Istanbul
APP_URL=https://gemdtek.com

APP_LOCALE=tr
APP_FALLBACK_LOCALE=tr
APP_FAKER_LOCALE=tr_TR

# Database — Natro MySQL bilgileri cPanel'de
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gemdtekcom_main
DB_USERNAME=gemdtekcom_user
DB_PASSWORD=                    # cPanel'den oluşturduğun şifre

# Cache / Session / Queue — DB-backed (Natro Redis vermez)
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_DOMAIN=.gemdtek.com
QUEUE_CONNECTION=database

# Mail (Natro SMTP)
MAIL_MAILER=smtp
MAIL_HOST=mail.gemdtek.com
MAIL_PORT=587
MAIL_USERNAME=noreply@gemdtek.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@gemdtek.com"
MAIL_FROM_NAME="${APP_NAME}"

# Filesystem — public disk
FILESYSTEM_DISK=public

# Logging
LOG_CHANNEL=daily
LOG_LEVEL=warning

# Bootstrap admin (sadece ilk seed çalışırsa kullanılır)
ADMIN_NAME="GEMDTEK Admin"
ADMIN_EMAIL=admin@gemdtek.com
ADMIN_PASSWORD=                 # Güçlü bir şifre koy; ilk girişten sonra değiştir

# Yeni form submission + iletişim mesajı bildirimi gönderilecek adres
# Boş bırakılırsa MAIL_FROM_ADDRESS'e gönderilir.
FORM_NOTIFICATION_EMAIL=basvurular@gemdtek.com
