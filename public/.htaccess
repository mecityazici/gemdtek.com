<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # ------------------------------------------------------------
    # 1) Force HTTPS (idempotent — won't loop behind Cloudflare/CDN)
    # ------------------------------------------------------------
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP:X-Forwarded-Proto} !=https
    RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

    # ------------------------------------------------------------
    # 2) www → apex (canonical: https://gemdtek.com)
    # ------------------------------------------------------------
    RewriteCond %{HTTP_HOST} ^www\.gemdtek\.com$ [NC]
    RewriteRule ^(.*)$ https://gemdtek.com/$1 [R=301,L]

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# ============================================================
# GEMDTEK production tuning
# ============================================================

# Gzip / deflate
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml application/x-font-ttf font/opentype
</IfModule>

# Brotli (if available — Natro sometimes has it)
<IfModule mod_brotli.c>
    AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# Browser cache (static assets — long term)
<IfModule mod_expires.c>
    ExpiresActive On

    ExpiresByType image/jpeg                    "access plus 1 year"
    ExpiresByType image/png                     "access plus 1 year"
    ExpiresByType image/webp                    "access plus 1 year"
    ExpiresByType image/svg+xml                 "access plus 1 year"
    ExpiresByType image/x-icon                  "access plus 1 year"

    ExpiresByType text/css                      "access plus 1 month"
    ExpiresByType application/javascript        "access plus 1 month"

    ExpiresByType font/woff                     "access plus 1 year"
    ExpiresByType font/woff2                    "access plus 1 year"
    ExpiresByType application/font-woff2        "access plus 1 year"

    # Vite hashes assets — safe to cache aggressively
    <FilesMatch "\.(css|js|woff2)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>

    # HTML / dynamic responses — short cache
    ExpiresByType text/html                     "access plus 0 seconds"
</IfModule>

# Service worker — must never cache (or PWA updates won't ship)
<FilesMatch "^sw\.js$">
    <IfModule mod_headers.c>
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </IfModule>
</FilesMatch>

# manifest.json — short cache (so PWA metadata updates propagate)
<FilesMatch "^manifest\.json$">
    <IfModule mod_headers.c>
        Header set Cache-Control "public, max-age=3600"
    </IfModule>
</FilesMatch>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    # HSTS — enable AFTER you've verified HTTPS works for at least a day.
    # Once a browser sees this it will refuse plain http for 1 year.
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# Block access to sensitive files (defence in depth — app code is outside web root anyway)
<FilesMatch "(?i)(\.env|\.git|composer\.(json|lock)|package(-lock)?\.json|artisan|phpunit\.xml|\.htaccess|\.user\.ini)$">
    Require all denied
</FilesMatch>
